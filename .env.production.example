# ============================================================
# ShelfLife AI — Production Environment Variables
# ============================================================
# Copy this file to .env.production and fill in all values.
# Store ALL secrets in Coolify's environment variable manager
# — never commit real values to Git.
#
# In Coolify: Application → Environment Variables → paste each line
# ============================================================


# ── Database ─────────────────────────────────────────────────────
# Internal Docker network URL — "postgres" is the service name in compose
DATABASE_URL=postgresql://shelflife:CHANGE_THIS_PASSWORD@postgres:5432/shelflife

# Postgres credentials (used by both postgres service and api service)
POSTGRES_USER=shelflife
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD   # generate: openssl rand -hex 24


# ── Redis ─────────────────────────────────────────────────────────
# Internal Docker network URL
REDIS_URL=redis://redis:6379/0


# ── MLflow ────────────────────────────────────────────────────────
# Internal Docker network URL (api talks to mlflow directly)
MLFLOW_TRACKING_URI=http://mlflow:5000


# ── API Security ──────────────────────────────────────────────────
# Strong random key — share this with API consumers
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_THIS_KEY

# Workers: use 2 for CX32 (2 vCPU), 4 for CX42 (4 vCPU)
API_WORKERS=2

# Your dashboard domain — used for CORS
# Format: https://app.yourdomain.com (no trailing slash)
DASHBOARD_DOMAIN=app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO


# ── GitHub (for docker-compose.prod.yml image pull) ───────────────
# Your GitHub username in lowercase
GITHUB_USERNAME=your-github-username


# ── Models ────────────────────────────────────────────────────────
DEMAND_MODEL_NAME=shelflife-demand-forecast
WASTE_MODEL_NAME=shelflife-waste-risk
MODEL_STAGE=Production


# ── Cache ─────────────────────────────────────────────────────────
CACHE_TTL_SAME_DAY=3600     # 1 hour
CACHE_TTL_FUTURE=21600      # 6 hours


# ── MLOps Thresholds ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RETRAIN_SCHEDULE_DAYS=7
DRIFT_PSI_THRESHOLD=0.2
MAPE_ALERT_THRESHOLD=0.20


# ── Backup (used by scripts/backup_db.sh) ─────────────────────────
# Where to store DB backups on the server
BACKUP_DIR=/var/backups/shelflife
# How many days of backups to keep
BACKUP_RETENTION_DAYS=14
